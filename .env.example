# ============================================================================
# Variables de entorno. En produccion NO se usa este archivo:
# los secretos viven en Secret Manager y se inyectan a Cloud Run.
# Este archivo es solo referencia y para desarrollo local.
# ============================================================================

# --- Proyecto ---
FIREBASE_PROJECT_ID=mi-proyecto-gcp
FIRESTORE_DATABASE_ID=llamadas_atencion

# --- Secretos (Secret Manager en produccion) ---
# Token de la API de ClickUp (pk_...). ROTAR el que estaba en el codigo viejo.
CLICKUP_TOKEN=pk_xxxxxxxx
# Bot token de Slack (xoxb-...). ROTAR el que estaba en el codigo viejo.
SLACK_BOT_TOKEN=xoxb-xxxxxxxx
# Secreto compartido que ClickUp manda en el query ?secret=... del webhook.
WEBHOOK_SECRET=cambia-esto-por-algo-largo-y-random

# --- Auth admin ---
# Correos con acceso al panel, separados por coma. Los roles finos (admin vs
# superadmin) se controlan por custom claims; esta lista es un cerrojo extra.
ADMIN_EMAILS=tu-correo@empresa.com

# --- CORS (solo si el panel corre en otro origen sin rewrite de Hosting) ---
ALLOWED_ORIGIN=

# --- Local only: credenciales de servicio para firebase-admin ---
# En Cloud Run NO se define: se usa Application Default Credentials (ADC).
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# --- Emulador (solo tests/local) ---
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

PORT=8080
