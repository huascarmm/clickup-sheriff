rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // El cliente (panel) NUNCA accede directo a Firestore.
    // Todas las lecturas/escrituras pasan por la API en Cloud Run (firebase-admin,
    // que ignora estas reglas). Asi el control de acceso vive en un solo lugar:
    // verificacion de ID token + custom claims en el backend.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
